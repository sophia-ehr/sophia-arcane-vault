# SOPHIA Arcane Vault — environment configuration
# Copy to .env and fill in secrets. This file is committed; .env is gitignored.

# Brain directory (absolute path on server; relative locally)
GBRAIN_BRAIN_DIR=../sophia-brain

# Link extraction directory whitelist (extends BASE_DIRS in link-extraction.ts)
GBRAIN_LINK_DIRS=organizations,tools,strategy,conferences,decisions,deliverables,sophia

# Search source boosts — tiered relevance weighting per directory
GBRAIN_SOURCE_BOOST="strategy/:1.5,organizations/:1.3,people/:1.2,decisions/:1.2,concepts/:1.2,tools/:1.1,deliverables/:1.0,conferences/:1.0,meetings/:1.0,inbox/:0.8,sources/:0.7,archive/:0.6"

# Exclude paths from search
GBRAIN_SEARCH_EXCLUDE=".raw/,archive/"

# API keys (fill in .env, never commit)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZEROENTROPY_API_KEY=
